<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <PipelineSequence name="NavigateWithReplanning">
      <RateController hz="1.0">
        <RecoveryNode number_of_retries="6" name="ComputePathToPose">
          <PipelineSequence name="NavigateWithReplanning">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="AStar" />
            <FollowPath path="{path}" controller_id="FollowPath" />
          </PipelineSequence>
          <ReactiveFallback name="RecoveryFallback">
            <ClearEntirelyCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
            <ClearEntirelyCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
          </ReactiveFallback>
        </RecoveryNode>
      </RateController>
    </PipelineSequence>
  </BehaviorTree>
</root>